# === Servidor Medplum ===
# URL base de la API del servidor Medplum (un solo servidor para ambos Projects).
MEDPLUM_BASE_URL=https://api.medplum.com.ar/

# (Opcional) Client ID de una ClientApplication de Medplum (flujo PKCE).
MEDPLUM_CLIENT_ID=

# === Projects FHIR (una institución por Project) ===
# Project ID (UUID) de cada institución en el servidor Medplum.
MEDPLUM_PROJECT_ID_BIO=
MEDPLUM_PROJECT_ID_RECEPCION=

# === Login con Google (opcional) ===
# Google OAuth Client ID. Debe estar habilitado en el servidor Medplum.
GOOGLE_CLIENT_ID=

# (Opcional) reCAPTCHA site key, si el servidor lo exige en el login/registro.
RECAPTCHA_SITE_KEY=
